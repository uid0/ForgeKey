.pio
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# OTA firmware-signing keypair output. Private key MUST never be committed;
# the public key gets baked into src/security/firmware_pubkey.h instead.
.firmware-keys/

# Per-developer predefined WiFi credentials picked up by src/wifi_setup/secrets.h.
# Copy secrets_local.example.h to secrets_local.h and fill in your dev networks.
src/wifi_setup/secrets_local.h

# Versioned firmware binaries produced by scripts/build/version.py post-build
# hook. These are build outputs, not source — staff upload them to OMS for OTA
# dispatch but they should not live in the repo.
artifacts/

# Beads / Dolt working state. The gt + bd tooling can leave nested .beads/
# directories under sibling working trees (e.g. when a cross-rig command runs
# from this worktree). Dolt manages its own .dolt/ internals and committing
# them into git history corrupts the live database — never let an auto-save
# safety net pick them up.
.beads/
**/.beads/
oms/
